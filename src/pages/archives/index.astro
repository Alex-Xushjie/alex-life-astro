---
import { getCollection } from 'astro:content';
import BlogLayout from '@/layouts/BlogLayout.astro';
import PostList from '@/components/PostList.astro';
import { resolveCover } from '@/pages/_imageStore';

const allPosts = await getCollection('blog');
const sorted = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const postData = sorted.map((p) => ({
  ...p,
  slug: p.id,
  data: {
    ...p.data,
    cover: resolveCover('blog', p.id, p.data.cover),
  },
}));

const totalPosts = allPosts.length;
const categories = new Set(allPosts.map(p => p.data.category).filter(Boolean)).size;
const tags = new Set(allPosts.flatMap(p => p.data.tags || [])).size;
---

<BlogLayout title="Archives">
  <header class="mb-10">
    <p class="text-sm text-[var(--color-primary)] font-medium mb-2 tracking-wide uppercase">Archives</p>
    <h1 class="text-3xl sm:text-4xl font-bold mb-3">Article Archives</h1>
    <p class="text-[var(--color-text-secondary)]">
      Total <span class="text-[var(--color-primary)] font-semibold">{totalPosts}</span> posts across <span class="text-[var(--color-primary)] font-semibold">{categories}</span> categories and <span class="text-[var(--color-primary)] font-semibold">{tags}</span> tags.
    </p>
  </header>
  <PostList posts={postData} />
</BlogLayout>
